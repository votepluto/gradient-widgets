      const d = (date.getTime() - Date.UTC(2000,0,1,12,0,0)) / 86400000;
      const L = normaliseDegrees(218.316 + 13.176396*d);
      const M = normaliseDegrees(134.963 + 13.064993*d);
      const D = normaliseDegrees(297.850 + 12.190749*d);
      const F = normaliseDegrees(93.272 + 13.229350*d);
      const Ms = normaliseDegrees(357.529 + .98560028*d);
      return normaliseDegrees(L + 6.289*sinDeg(M) + 1.274*sinDeg(2*D-M) + .658*sinDeg(2*D) + .214*sinDeg(2*M) - .186*sinDeg(Ms) - .114*sinDeg(2*F));
