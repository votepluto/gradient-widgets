      if (pct < .025 || pct > .975) return { name:"New Moon", pct };
      if (pct < .25) return { name:"Waxing Crescent", pct };
      if (pct < .275) return { name:"First Quarter", pct };
      if (pct < .475) return { name:"Waxing Gibbous", pct };
      if (pct < .525) return { name:"Full Moon", namedMoon:getSouthernNamedMoon(date), pct };
      if (pct < .725) return { name:"Waning Gibbous", pct };
      if (pct < .775) return { name:"Last Quarter", pct };
