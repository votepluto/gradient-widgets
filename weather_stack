      const goPrevMonth=()=> { setMonthBannerOpen(false); return viewMonth===0 ? (setViewMonth(11),setViewYear(y=>y-1)) : setViewMonth(m=>m-1); };
      const goNextMonth=()=> { setMonthBannerOpen(false); return viewMonth===11 ? (setViewMonth(0),setViewYear(y=>y+1)) : setViewMonth(m=>m+1); };

      const DrawerToggle = ({open,onClick}) => <div className="toggle-row"><button className="toggle-btn" onClick={onClick} aria-label="Toggle details"><svg className={`arrow ${open?'open':''}`} width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4.5 7 L9 11 L13.5 7" stroke="rgba(88,74,98,.46)" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"/></svg></button></div>;

      return <div className="widget-stack">
        <div className="card-shell pair-top"><div className="card time-card"><div className="time-line"><div className="time-main"><span key={`${time.h}:${time.m}`} className="time-main-pop">{time.h}<span className="time-colon">:</span>{time.m}</span></div><div className="time-seconds">{time.s}</div></div><div className="date-line">{time.date}</div></div></div>

        <div className="card-shell pair-bottom"><div className="card weather-card" onClick={addRipple}>{ripples.map(r=><div key={r.id} className="ripple-wave" style={{left:r.x,top:r.y}}/>)}<div className="section-main"><div className="weather-row"><div><div className="eyebrow">Weather</div><div className="weather-temp-line"><div className="weather-temp">{weather.temp!==null?`${weather.temp}°`:'—'}</div><div className="weather-label">{weather.label}</div></div></div><WeatherIcon type={weather.type}/></div></div><div className={`drawer ${weatherOpen?'open':''}`}><div className="weather-summary"><div className="summary-hero"><div className="summary-label">Feels Like</div><div className="summary-hero-line"><div className="summary-main-value">{weather.feels!==null?`${weather.feels}°`:'—'}</div><div className="summary-note">{weather.high!==null&&weather.low!==null?`High ${weather.high}° · Low ${weather.low}°`:'Today'}</div></div></div><div className="summary-list">{[{label:'Sunset',value:weather.sunset?`${sunsetCountdown(weather.sunset)} · ${new Date(weather.sunset).toLocaleTimeString('en-AU',{hour:'2-digit',minute:'2-digit'})}`:'—'},{label:'Next Hour',value:weather.nextHourTemp!==null?`${weather.nextHourTemp}°`:'—'},{label:'Rain Chance',value:weather.rainProb!=null?`${weather.rainProb}%`:'—'},{label:'Wind',value:weather.wind!=null?`${windDescription(weather.wind)} · ${degToCompass(weather.windDir)}`:'—'}].map(item=><div key={item.label} className="summary-row"><div className="summary-row-label">{item.label}</div><div className="summary-row-value">{item.value}</div></div>)}</div></div></div><DrawerToggle open={weatherOpen} onClick={e=>{e.stopPropagation(); const card=document.querySelector('.weather-card'); const rect=e.currentTarget.getBoundingClientRect(); if(card)addRipple({currentTarget:card,clientX:rect.left+rect.width/2,clientY:rect.top+rect.height/2}); setWeatherOpen(v=>!v);}}/></div></div>

        <div className="card-shell">
          <div className="card astro-card">
            <div className="section-main">
              <div className="astro-row">
                <div>
                  <div className="eyebrow">Lunar</div>
                  <div className="astro-main">{astro.moonPhase}</div>
                  <div className="astro-sub">{astro.namedMoon} · Moon in {astro.moonSign}</div>
                </div>
                <div className="astro-orb"></div>
              </div>
            </div>

            <div className={`drawer ${astroOpen ? 'open' : ''}`}>
              <div className="lunar-guide">
                <div className="lunar-guide-hero">
                  <div className="lunar-guide-label">Lunar Guide</div>
                  <div className="lunar-guide-title">{astro.namedMoon}</div>
                  <div className="lunar-guide-copy">
                    {astro.namedMoon === 'Beaver Moon'
                      ? 'Traditionally linked with preparation and protection — a cue to organise, secure, and get things in place.'
                      : 'A seasonal moon marker connected to nature cycles, reflection, and timing.'}
                  </div>
                </div>

                <div className="lunar-note-list">
                  <div className="lunar-note">
                    <div className="lunar-note-title">Moon in {astro.moonSign}</div>
                    <div className="lunar-note-copy">
                      {astro.moonSign === 'Sagittarius'
                        ? 'The emotional tone leans toward perspective, learning, truth-seeking, and looking ahead.'
                        : 'The Moon sign describes the current emotional tone and where attention naturally gathers.'}
                    </div>
                  </div>

                  <div className="lunar-note">
                    <div className="lunar-note-title">Good for</div>
                    <div className="lunar-note-copy">
                      {astro.moonPhase.includes('Waning')
                        ? 'Reflecting, wrapping things up, and releasing what no longer needs your energy.'
                        : astro.moonPhase.includes('Waxing')
                        ? 'Starting small, building momentum, and feeding what you want to grow.'
                        : astro.moonPhase.includes('Full')
                        ? 'Clarity, decisions, completion, and noticing what has come to light.'
                        : 'Setting intentions, resetting gently, and choosing what you want to begin.'}
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <DrawerToggle open={astroOpen} onClick={e=>{e.stopPropagation();setAstroOpen(v=>!v);}}/>
          </div>
        </div>

        <div className="card-shell"><div className="card calendar-card"><div className="section-main"><div className="calendar-header"><div><div className="eyebrow">Calendar</div><div className="calendar-title">{MONTHS[viewMonth]}</div><div className="calendar-year">{viewYear}</div></div><div className="calendar-controls"><button className="calendar-btn" onClick={goPrevMonth} aria-label="Previous month">‹</button><button className="calendar-btn" onClick={goNextMonth} aria-label="Next month">›</button></div></div>{primaryMonthBanner && <div className="month-banner" onClick={()=>setMonthBannerOpen(v=>!v)}>
                    <div className="month-banner-top">
                      <div className="month-banner-title">
                        <span className="month-banner-dot" style={{background:getEventColor(primaryMonthBanner.color)}}></span>
                        <span>{primaryMonthBanner.title}</span>
                      </div>
                      <svg className={`month-banner-arrow ${monthBannerOpen ? 'open' : ''}`} width="18" height="18" viewBox="0 0 18 18" fill="none">
                        <path d="M4.5 7 L9 11 L13.5 7" stroke="rgba(88,74,98,.46)" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"/>
                      </svg>
                    </div>
                  </div>}
                  <div className={`drawer ${monthBannerOpen && monthBannerEvents.length ? 'open' : ''}`}>
                    <div className="weather-summary calendar-event-summary">
                      {monthBannerEvents.map((event, idx) => (
                        <div className="agenda-item" key={`${event.title}-${idx}`}>
                          <div className="agenda-tag" style={{marginLeft:0, marginBottom:8}}>{event.tag}</div>
                          <div className="agenda-copy" style={{marginLeft:0}}>{event.desc}</div>
                        </div>
                      ))}
                    </div>
                  </div>
                  <div className="weekday-grid">{DAYS.map((d,i)=><div key={i} className="weekday">{d}</div>)}</div><div className="calendar-grid">{calendarCells.map((cell,i)=>{const isToday=cell.y===today.getFullYear()&&cell.m===today.getMonth()&&cell.d===today.getDate(); const isSelected=cell.y===selectedDate.y&&cell.m===selectedDate.m&&cell.d===selectedDate.d; const events=getEventsForDate(cell); const event=events[0]; const hasEvent=events.length>0; return <div key={i} className={`day-cell ${cell.other?'other':''} ${isToday?'today':''} ${isSelected?'selected':''} ${hasEvent?'has-event':''}`} onClick={()=>{setSelectedDate({y:cell.y,m:cell.m,d:cell.d});setCalendarOpen(!!getEventForDate(cell));}}>{cell.d}{hasEvent && <><span style={{position:'absolute',bottom:4,left:'50%',transform:'translateX(-50%)',width:5,height:5,borderRadius:'50%',background:getEventColor(event.color),boxShadow:'0 0 8px rgba(180,160,220,0.15)'}} /><div className="event-tooltip"><div className="event-tooltip-title">{event.title}</div><div className="event-tooltip-tag">{events.length > 1 ? `${events.length} events` : event.tag}</div></div></>}</div>;})}</div></div><div className={`drawer ${calendarOpen && selectedEvent ? 'open' : ''}`}>
                {selectedEvent && (
                  <div className="weather-summary calendar-event-summary">
                    <div className="agenda-header">
                      {selectedWeekday} · {ordinal(selectedDate.d)} {MONTHS[selectedDate.m]} {selectedDate.y}
                    </div>
                    {selectedEvents.map((event, idx) => (
                      <div className="agenda-item" key={`${event.title}-${idx}`}>
                        <div className="agenda-title-row">
                          <div className="agenda-title">
                            <span className="agenda-dot" style={{background:getEventColor(event.color)}}></span>
                            <span>{event.title}</span>
                          </div>
                          <div className="agenda-tag">{event.tag}</div>
                        </div>
                        <div className="agenda-copy">{event.desc}</div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
              {selectedEvent && <DrawerToggle open={calendarOpen} onClick={e=>{e.stopPropagation();setCalendarOpen(v=>!v);}}/>}
            </div>
          </div>
      </div>;
    }

    ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
  </script>
</body>
</html>
